  .cursor-blink {
    display: inline-block; width: 8px; height: 1em;
    background: var(--accent); vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }
  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0; } }
</style>
